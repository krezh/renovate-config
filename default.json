{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "replacements:k8s-registry-move",
    "replacements:containerbase",
    ":semanticCommits",
    "github>home-operations/renovate-presets#2.0.0",
    "github>krezh/renovate-config:labels.json5",
    "github>krezh/renovate-config:commitMessage.json5",
    "github>krezh/renovate-config:semanticCommits.json5",
    "github>krezh/renovate-config:automerge-github-actions.json5",
    "github>krezh/renovate-config:automerge-renovate.json5",
    "github>krezh/renovate-config:hostRules.json5"
  ],
  "timezone": "Europe/Stockholm",
  "platform": "github",
  "platformCommit": "enabled",
  "onboarding": false,
  "requireConfig": "required",
  "configMigration": true,
  "suppressNotifications": [
    "prEditedNotification",
    "prIgnoreNotification"
  ],
  "assigneesFromCodeOwners": false,
  "reviewersFromCodeOwners": true,
  "stopUpdatingLabel": "renovate/stop",
  "rebaseWhen": "conflicted",
  "ignorePaths": [
    "**/archive/**",
    "**/.archive/**",
    "**/*.sops.*"
  ]
}