{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["github>krezh/renovate-config"],
  allowedCommands: [
    "^nix run github:Mic92/nix-update",
    "^nix run github:nix-community/gomod2nix",
    "^nix run github:purpleclay/go-overlay#govendor",
    "^nix run nixpkgs#crate2nix",
    "^bash .github/scripts/update-hash.sh",
  ],
}
